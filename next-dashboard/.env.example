# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres"

# ─── Auth.js ──────────────────────────────────────────────────────────────
# Required: secret for signing JWT session tokens.
# Generate: `openssl rand -base64 32` or `npx auth secret`
AUTH_SECRET="zmen-toto-na-silne-tajomstvo"

# Required in production: canonical URL of the deployment (Auth.js needs it
# for OAuth callbacks). On Vercel this is auto-set; locally it's optional.
# AUTH_URL="https://pro-dashboard.vercel.app"

# ─── Google OAuth (production sign-in) ────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Dev login (development only) ─────────────────────────────────────────
# Enables passwordless sign-in by email — only works for users that already
# exist in the User table. NEVER set to true in production.
# Defaults to true when NODE_ENV !== 'production'.
DEV_LOGIN_ENABLED="true"

# ─── Logging ──────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL="debug"

# ─── Legacy admin endpoints (will be migrated to ADMIN role) ──────────────
# Currently no longer needed — admin endpoints check session role.
# Kept temporarily for any external scripts that might still call them.
# ADMIN_SECRET=""
